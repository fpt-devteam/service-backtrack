{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Firebase": {
    "ProjectId": "your-firebase-project-id",
    "ServiceAccountJsonBase64": ""
  },
  "ReverseProxy": {
    "Routes": {
      "core-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/core/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "chat-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/chat/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "chat-socket-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/api/chat/hub/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/api/chat"
          }
        ]
      },
      "chat-ws-route": {
        "ClusterId": "chat-cluster",
        "Match": {
          "Path": "/chat/hub/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/chat"
          }
        ]
      },
    },
    "Clusters": {
      "core-cluster": {
        "Destinations": {
          "core-destination": {
            "Address": ""
          }
        },
        "HttpRequest": {
          "Timeout": "00:00:30"
        }
      },
      "chat-cluster": {
        "Destinations": {
          "chat-destination": {
            "Address": ""
          }
        }
      },
    }
  }
}